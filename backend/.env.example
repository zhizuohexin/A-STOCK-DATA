# Tushare Pro token (https://tushare.pro)
TUSHARE_TOKEN=your_token_here

# SQLite database path (inside container this is /app/data/stocks.db)
DATABASE_URL=sqlite:////app/data/stocks.db

# API server
API_HOST=0.0.0.0
API_PORT=8000

# CORS (comma separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost

# Scheduler
SCHEDULER_ENABLED=true
# Daily job run time (Asia/Shanghai, after market close)
DAILY_JOB_HOUR=16
DAILY_JOB_MINUTE=0
# Intraday cleanup time (Asia/Shanghai, before market open)
CLEANUP_JOB_HOUR=8
CLEANUP_JOB_MINUTE=30
